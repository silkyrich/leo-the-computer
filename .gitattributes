# Only bulk/historical generated content uses LFS
# asset_sets/ and generated/images/pages/ are regular git objects — need public raw URLs

generated/images/other-projects/**/*.png filter=lfs diff=lfs merge=lfs -text
generated/images/other-projects/**/*.jpg filter=lfs diff=lfs merge=lfs -text
generated/images/reference/**/*.png filter=lfs diff=lfs merge=lfs -text
generated/images/reference/**/*.jpg filter=lfs diff=lfs merge=lfs -text
generated/images/*.png filter=lfs diff=lfs merge=lfs -text
generated/images/*.jpg filter=lfs diff=lfs merge=lfs -text
generated/images/set_*.png filter=lfs diff=lfs merge=lfs -text
asset_sets/**/*.png filter=lfs diff=lfs merge=lfs -text
asset_sets/**/*.jpg filter=lfs diff=lfs merge=lfs -text
generated/images/pages/**/*.png filter=lfs diff=lfs merge=lfs -text
generated/images/pages/**/*.jpg filter=lfs diff=lfs merge=lfs -text
